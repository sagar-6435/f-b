# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/freshbasket?retryWrites=true&w=majority

# Server port (Render auto-provides this, defaults to 3000 locally)
PORT=3000

# Twilio credentials for OTP SMS
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Firebase Cloud Messaging — for push notifications
# Project settings → Cloud Messaging → Server key (Legacy)
FCM_SERVER_KEY=your_fcm_server_key
