{
  "expo": {
    "name": "Fresh Basket",
    "slug": "fresh-basket-expo",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "icon": "./icon.png",
    "splash": {
      "image": "./icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F4"
    },
    "plugins": ["expo-notifications", "@react-native-firebase/app", "@react-native-firebase/auth"],
    "android": {
      "package": "com.webgenixx.FreshBasket",
      "googleServicesFile": "./server/google-services.json",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION", "POST_NOTIFICATIONS"]
    },
    "ios": {
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Fresh Basket uses your location to show delivery coverage and nearby service availability."
      }
    }
  }
}
